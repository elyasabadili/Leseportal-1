{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "Represents a book in the library catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the book" },
        "isbn": { "type": "string", "description": "ISBN code of the book" },
        "title": { "type": "string", "description": "Title of the book" },
        "author": { "type": "string", "description": "Author of the book" },
        "description": { "type": "string", "description": "Short summary of the book" },
        "genre": { "type": "string", "description": "Genre/category of the book" },
        "price": { "type": "number", "description": "Acquisition price of the book" },
        "pages": { "type": "number", "description": "Total page count" },
        "status": { "type": "string", "enum": ["available", "borrowed"] },
        "borrowerId": { "type": "string", "description": "ID of the member currently borrowing this book" },
        "borrowerName": { "type": "string", "description": "Name of the borrower" },
        "dueDate": { "type": "string", "description": "Due date in YYYY-MM-DD format" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "author", "status", "createdAt"]
    },
    "Member": {
      "title": "Member",
      "description": "Represents a library card owner (Teacher or Student)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique member card ID (S-XXXXX or L-XXXXX)" },
        "name": { "type": "string", "description": "Full name of the member" },
        "role": { "type": "string", "enum": ["Schüler", "Lehrer"] },
        "classOrSubject": { "type": "string", "description": "Class code for Schüler or subjects for Lehrer" },
        "barcode": { "type": "string", "description": "Barcode content corresponding to the card ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role", "barcode", "createdAt"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Represents a book loan record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID" },
        "bookId": { "type": "string", "description": "Reference book ID" },
        "bookTitle": { "type": "string", "description": "Title of the borrowed book" },
        "memberId": { "type": "string", "description": "Reference member ID" },
        "memberName": { "type": "string", "description": "Name of the borrower" },
        "memberRole": { "type": "string", "enum": ["Schüler", "Lehrer"] },
        "loanDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "returnDate": { "type": "string", "description": "Date returned, or null if active" },
        "extendedCount": { "type": "number", "description": "Number of times extended" },
        "status": { "type": "string", "enum": ["active", "returned", "overdue"] }
      },
      "required": ["id", "bookId", "bookTitle", "memberId", "memberName", "memberRole", "loanDate", "dueDate", "extendedCount", "status"]
    },
    "LibraryUser": {
      "title": "LibraryUser",
      "description": "User account for credentials authentication",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique user ID" },
        "username": { "type": "string", "description": "Unique username" },
        "passwordHash": { "type": "string", "description": "Plain text or simple secure password string" },
        "name": { "type": "string", "description": "Full name of the user" },
        "role": { "type": "string", "enum": ["Schüler", "Lehrer", "Bücherei-Lehrer/in", "Superadmin"] },
        "classOrSubject": { "type": "string", "description": "Class or subject description" },
        "memberId": { "type": "string", "description": "ID of associated library member" },
        "schoolCode": { "type": "string", "description": "School identification code" },
        "isActive": { "type": "boolean", "description": "Whether the user account is active" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "passwordHash", "name", "role", "schoolCode", "createdAt"]
    },
    "School": {
      "title": "School",
      "description": "Represents a school registered in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique school code / identification" },
        "name": { "type": "string", "description": "Name of the school" },
        "isActive": { "type": "boolean", "description": "Whether the school code is active" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "isActive", "createdAt"]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of all books in the catalog"
    },
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of registered member profiles and library cards"
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Collection of current and past lending agreements"
    },
    "/users/{userId}": {
      "schema": "LibraryUser",
      "description": "Collection of authenticated user credentials"
    },
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Collection of all registered schools and school codes"
    }
  }
}
